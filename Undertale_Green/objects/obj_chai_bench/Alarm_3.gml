global.msg[0] = "[character,chai,remorsefulcry][delay,1]* Look,[freeze][delay,333][continue] I'm not really a\n  touchy-feely kinda\n  person.[/page]";
global.msg[1] = "[character,chai,remorsefulcry][delay,1]* But I know you are.[/page]";
global.msg[2] = "[character,chai,remorsefulcry][delay,1]* So...[/page]";
global.msg[3] = "[character,chai,crysmile][delay,1]* I care about you,[freeze][delay,333][continue]\n  alright?[/page]";
global.msg[4] = "[character,chai,crysmile][delay,1]* Please don't wander\n  into a haunted murder\n  forest again.[/page]";
global.msg[5] = "[character,chai,blinksmile][delay,1]* Nearly killed me too.[hug]";
instance_create_depth(x, y, -1000, obj_textboxNEW);
