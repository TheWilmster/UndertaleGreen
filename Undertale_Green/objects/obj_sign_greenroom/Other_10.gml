global.msg[0] = "[character,none,-1][delay,5]* You don't know what it says.[/page]";
global.msg[1] = "[character,none,-1][delay,5]* You think about asking someone\n  about it,[delay,333] but then you remember\n  your mom's 'stranger danger.'[/page]";
global.msg[2] = "[character,none,-1][delay,5]* 'If I ever see you with a\n  stranger,[delay,333] you're in danger.'";
global.msg_esp[0] = "[character,none,-1][delay,5]* No sabes lo que dice.[/page]";
global.msg_esp[1] = "[character,none,-1][delay,5]* Piensas sobre preguntarle\n  a alguien,[delay,333] pero te acuerdas\n  de lo que decía tu mamá.[/page]";
global.msg_esp[2] = "[character,none,-1][delay,5]* 'Nunca confíes en desconocidos,\n  te pueden meter en problemas'.\n  Y de cómo incluía...[/page]";
global.msg_esp[3] = "[character,none,-1][delay,5]* 'Y como yo te vea siguiendo\n  a uno, YO soy el problema.'";
instance_create_depth(x, y, -1000, obj_textboxNEW);
