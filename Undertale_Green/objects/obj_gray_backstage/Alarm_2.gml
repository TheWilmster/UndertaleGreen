global.msg[0] = "[character,gray,condescending][owsprite,gray_bs,smile][delay,1]* What's up kid?[freeze][delay,333][continue]\n* You're Chai's sibling,[freeze][delay,333][continue]\n  right?[/page]";
global.msg[1] = "[character,gray,nervous][owsprite,gray_bs,curious][delay,1]* ...[freeze][delay,333][continue]You okay?[/page]";
global.msg[2] = "[character,none,-1][delay,1]* (You tell him Chai was supposed\n  to be here.)[/page]";
global.msg[3] = "[character,gray,smug][delay,1][owsprite,gray_bs,default]* Unfortunate.[freeze][delay,333][continue]\n* She was just here a\n  second ago.[/page]";
global.msg[4] = "[character,gray,smug][delay,1][owsprite,gray_bs,smug]* Maybe she and her\n  pit punks heard the\n  smoke alarm.[/page]";
global.msg[5] = "[character,gray,smug][delay,1]* If you know what I\n  mean.[/page]";
global.msg[6] = "[character,gray,flustered][delay,1][owsprite,gray_bs,flustered]* On second thought you\n  probably shouldn't know\n  what I mean.[/page]";
global.msg[7] = "[character,gray,flustered][delay,1]* Forget I said that.[/page]";
global.msg[8] = "[character,gray,condescending][delay,1][owsprite,gray_bs,smile]* On the bright side,[freeze][delay,333][continue]\n  rehearsal's almost out.[freeze][delay,333][continue]\n* She should be here soon.[/page]";
global.msg[9] = "[character,gray,condescending][delay,1]* Just nailed my last\n  scene,[freeze][delay,333][continue] so I can keep you\n  company while you wait.[/page]";
global.msg[10] = "[character,none,-1][delay,1][owsprite,gray_bs,default]* (You ask him what his name\n  is.)[/page]";
global.msg[11] = "[character,gray,happy][delay,1][owsprite,gray_bs,smile]* My name's Gray.[freeze][delay,333][continue] Like\n  the color but spelled\n  with more freedom.[/page]";
global.msg[12] = "[character,gray,happy][delay,1][owsprite,gray_bs,default]* ...You look surprised.[/page]";
global.msg[13] = "[character,gray,dumb][delay,1][owsprite,gray_bs,smile]* People say I bite or\n  something?[/page]";
global.msg[14] = "[character,none,-1][delay,1][owsprite,gray_bs,default]* (You mention something happened\n  that Eden wanted to keep\n  secret.)[/page]";
global.msg[15] = "[character,gray,happy][delay,1]* See,[freeze][delay,333][continue] well now you have\n  to tell me.[freeze][delay,333][continue] I'm hangin'\n  off a cliff over here.[/page]";
global.msg[16] = "[character,gray,happy][delay,1]* It's cool,[freeze][delay,333][continue] alright?[freeze][delay,333][continue]\n  Listen,[freeze][delay,333][continue] if anything this\n  is on her.[/page]";
global.msg[17] = "[character,gray,smug][delay,1][owsprite,gray_bs,smug]* Girlfriends shouldn't\n  keep secrets.[/page]";
global.msg[18] = "[character,gray,holdingback][delay,1]* ...[/page]";
global.msg[19] = "[character,gray,silly][grayshake][owsprite,gray_bs,laughter][delay,1]* ...[/page]";
global.msg[20] = "[character,gray,shocked][owsprite,gray_bs,smile][delay,1]* What!?[freeze][delay,333][continue] No![freeze][delay,333][continue]\n* I'm taking this very\n  seriously.[/page]";
global.msg[21] = "[character,gray,happy][delay,1]* Thank you for confiding\n  in me,[freeze][delay,333][continue] little Chai.[/page]";
global.msg[22] = "[character,gray,happy][delay,1]* I'll only use this\n  information for good.[freeze][delay,333][continue]\n* Promise.[/page]";
global.msg[23] = "[character,gray,happy][delay,1]* So, wanna break out\n  those toys then?[/page]";
global.msg[24] = "[character,gray,happy][delay,1][owsprite,gray_bs,smug]* Let me tell you, your\n  bishop has nothing on\n  whatever I'm playing as.[/page]";
global.msg[25] = "[character,none,-1][delay,1]* (You tell him he's a knight.)[/page]";
global.msg[26] = "[character,gray,happy][delay,1]* See, now you're really\n  screwed.[/page]";
global.msg[27] = "[character,gray,happy][delay,1]* I actually know what\n  a knight is.[/page][battle,gray]";
global.msg_esp[0] = "[character,gray,condescending][owsprite,gray_bs,smile][delay,1]* ¿Qué pasa?[freeze][delay,333][continue]\n* Se te nota en la jeta\n  tu parentezco...[/page]";
global.msg_esp[1] = "[character,gray,condescending][owsprite,gray_bs,smile][delay,1]* ...con Chai.[freeze][delay,333][continue]\n* ¿No es así?[/page]";
global.msg_esp[2] = "[character,gray,nervous][owsprite,gray_bs,curious][delay,1]* ...[freeze][delay,333][continue]¿Estás bien?[/page]";
global.msg_esp[3] = "[character,none,-1][delay,1]* (Le dices que Chai debería de\n  estar aquí.)[/page]";
global.msg_esp[4] = "[character,gray,smug][delay,1][owsprite,gray_bs,default]* Mala suerte.[freeze][delay,333][continue]\n* Tu hermana acaba de\n  pasar por aquí...[/page]";
global.msg_esp[5] = "[character,gray,smug][delay,1][owsprite,gray_bs,default]* ...hace menos de un\n  minuto.[/page]";
global.msg_esp[6] = "[character,gray,smug][delay,1][owsprite,gray_bs,smug]* Creo que ella y su\n  pandilla se cuadraron\n  al ver la tira.[/page]";
global.msg_esp[7] = "[character,gray,smug][delay,1]* Si sabes a lo que me\n  refiero.[/page]";
global.msg_esp[8] = "[character,gray,flustered][delay,1][owsprite,gray_bs,flustered]* Pensándolo mejor,[freeze][delay,333][continue]\n  mejor que no sepas\n  a lo que me refiero.[/page]";
global.msg_esp[9] = "[character,gray,flustered][delay,1]* Olvida lo que acabo de\n  decir.[/page]";
global.msg_esp[10] = "[character,gray,condescending][delay,1][owsprite,gray_bs,smile]* Por otro lado,[freeze][delay,333][continue] el ensayo\n  está al terminar.[freeze][delay,333][continue] Tu\n  hermana aparecerá...[/page]";
global.msg_esp[11] = "[character,gray,condescending][delay,1][owsprite,gray_bs,smile]* ...pronto por aquí.[/page]";
global.msg_esp[12] = "[character,gray,condescending][delay,1]* He clavado mi actuación,[freeze][delay,333][continue]\n  con lo que tengo\n  suficiente tiempo para...[/page]";
global.msg_esp[13] = "[character,gray,condescending][delay,1]* ...echarte un vistazo.[/page]";
global.msg_esp[14] = "[character,none,-1][delay,1][owsprite,gray_bs,default]* (Le preguntas cuál es su\n  nombre.)[/page]";
global.msg_esp[15] = "[character,gray,happy][delay,1][owsprite,gray_bs,smile]* Me llamo Gray.[freeze][delay,333][continue] Como el\n  color,[freeze][delay,333][continue] pero en inglés.[/page]";
global.msg_esp[16] = "[character,gray,happy][delay,1][owsprite,gray_bs,default]* ...¿Y esa reacción?[/page]";
global.msg_esp[17] = "[character,gray,dumb][delay,1][owsprite,gray_bs,smile]* ¿Acaso te han dicho\n  cositas malas de mí?[/page]";
global.msg_esp[18] = "[character,none,-1][delay,1][owsprite,gray_bs,default]* (Le mencionas que Eden te ha\n  dicho que no puedes contarle\n  ciertas cosas.)[/page]";
global.msg_esp[19] = "[character,gray,happy][delay,1]* Ya veo...[freeze][delay,333][continue] Bueno,[freeze][delay,333][continue] ahora\n  que me lo has dicho,[freeze][delay,333][continue]\n  tendrás que contarme...[/page]";
global.msg_esp[20] = "[character,gray,happy][delay,1]* ...los secretitos.[/page]";
global.msg_esp[21] = "[character,gray,happy][delay,1]* No va a pasar nada,[freeze][delay,333][continue]\n  ¿vale?[/page]";
global.msg_esp[22] = "[character,gray,happy][delay,1]* Mira,[freeze][delay,333][continue] si no lo haces, la\n  culpa es suya.[/page]";
global.msg_esp[23] = "[character,gray,smug][delay,1][owsprite,gray_bs,smug]* Los novios no se pueden\n  guardar secretos,[freeze][delay,333][continue] ¿no\n  crees?[/page]";
global.msg_esp[24] = "[character,gray,holdingback][delay,1]* ...[/page]";
global.msg_esp[25] = "[character,gray,silly][grayshake][owsprite,gray_bs,laughter][delay,1]* ...[/page]";
global.msg_esp[26] = "[character,gray,shocked][owsprite,gray_bs,smile][delay,1]* ¿¡Qué!?[freeze][delay,333][continue] ¡No![freeze][delay,333][continue]\n* Me lo estoy tomando\n  muy seriamente.[/page]";
global.msg_esp[27] = "[character,gray,happy][delay,1]* Gracias por confiar en\n  mí,[freeze][delay,333][continue] mini-Chai.[/page]";
global.msg_esp[28] = "[character,gray,happy][delay,1]* Utilizaré esta\n  información\n  exclusivamente para...[/page]";
global.msg_esp[29] = "[character,gray,happy][delay,1]* ...un bien mayor.[freeze][delay,333][continue]\n* Lo prometo.[/page]";
global.msg_esp[30] = "[character,gray,happy][delay,1]* Entonces, ¿quieres\n  empezar a jugar?[/page]";
global.msg_esp[31] = "[character,gray,happy][delay,1][owsprite,gray_bs,smug]* Déjame decirte, tu\n  alfil no tiene\n  oportunidad alguna...[/page]";
global.msg_esp[32] = "[character,gray,happy][delay,1][owsprite,gray_bs,smug]* ...contra cualquier\n  pieza que me decidas dar.[/page]";
global.msg_esp[33] = "[character,none,-1][delay,1]* (Le dices que él es el caballo.)[/page]";
global.msg_esp[34] = "[character,gray,happy][delay,1]* Mala opción,[freeze][delay,333][continue] estás en un\n  gran aprieto.[/page]";
global.msg_esp[35] = "[character,gray,happy][delay,1]* ¿Acaso sabes quiénes\n  montaban a los caballos?[/page][battle,gray]";
if (!audio_is_playing(mus_gray))
	audio_play_sound(mus_gray, 1, true);
instance_create_depth(x, y, -1000, obj_textboxNEW);
