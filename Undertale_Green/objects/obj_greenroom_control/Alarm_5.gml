global.msg[0] = "[character,kaitlyn,ugh][delay,1]* ...[freeze][delay,333][continue]I am like,[freeze][delay,333][continue] so gonna\n  flip out if any creeps\n  find this place.[/page]";
global.msg[1] = "[character,destiny,smug][delay,1]* Why don't you talk\n  about it louder then?[/page]";
global.msg[2] = "[character,alaska,neutral][delay,1]* ...[freeze][delay,333][continue]So none of you watch\n  the news?[/page]";
global.msg[3] = "[character,chai,neutral][owsprite,chai,down][delay,1]* What do you mean?[/page]";
global.msg[4] = "[character,alaska,smug][owsprite,alaska,smug][delay,1]* They found some dead\n  dude at the place we're\n  going to tonight.[/page]";
global.msg[5] = "[character,chai,rolleyes][delay,1]* Wow,[freeze][delay,333][continue] I'm so scared\n  right now.[/page]";
global.msg[6] = "[character,alaska,smug][owsprite,alaska,up][delay,1]* Be scared if you want.[/page]";
global.msg[7] = "[character,alaska,smug][delay,1]* Doesn't change the fact\n  that there's a dead dude\n  over there.[/page]";
global.msg[8] = "[character,chai,rolleyes][delay,1]* ...[/page]";
global.msg[9] = "[character,chai,scared][owsprite,chai,scared][delay,1]* Really?[/page]";
global.msg[10] = "[character,destiny,smile][owsprite,destiny,right][owsprite,destiny,smile][destinymove][delay,1]* You're serious?[/page]";
global.msg[11] = "[character,alaska,smug][owsprite,alaska,smug][delay,1]* Dead serious.[freeze][delay,333][continue]\n* Just like the dude.[/page]";
global.msg[12] = "[character,kaitlyn,neutral][owsprite,chai,left][owsprite,chai,normal][delay,1]* She's right.[freeze][delay,333][continue] Happened\n  like a week ago.[/page]";
global.msg[13] = "[character,destiny,smile][owsprite,destiny,down][delay,1]* You knew?[/page]";
global.msg[14] = "[character,kaitlyn,neutral][owsprite,kaitlyn,up][delay,1]* Yeah.[/page]";
global.msg[15] = "[character,kaitlyn,neutral][delay,1]* Exactly why I'm worried\n  about some creeps\n  finding it.[/page]";
global.msg[16] = "[character,chai,scared][owsprite,kaitlyn,normal][owsprite,destiny,right][owsprite,destiny,normal][owsprite,chai,scared][delay,1]* Well now I am too![freeze][delay,333][continue] Can't\n  we just...[greenroomadvance1]";
global.msg_esp[0] = "[character,kaitlyn,ugh][delay,1]* ...[freeze][delay,333][continue]Tipo,[freeze][delay,333][continue] si algún tío\n  raro de esos encuentra\n  este lugar te juro...[/page]";
global.msg_esp[1] = "[character,destiny,smug][delay,1]* Anda,[freeze][delay,333][continue] dilo más alto,[freeze][delay,333][continue]\n  seguro que no te\n  escuchan.[/page]";
global.msg_esp[2] = "[character,alaska,neutral][delay,1]* ...[freeze][delay,333][continue]¿Ninguna ha visto\n  las noticias?[/page]";
global.msg_esp[3] = "[character,chai,neutral][owsprite,chai,down][delay,1]* ¿Qué quieres decir?[/page]";
global.msg_esp[4] = "[character,alaska,smug][owsprite,alaska,smug][delay,1]* Han encontrado a un tío\n  muerto donde vamos esta\n  noche.[/page]";
global.msg_esp[5] = "[character,chai,rolleyes][delay,1]* Guau,[freeze][delay,333][continue] Estoy muy\n  asustada,[freeze][delay,333][continue] mira mi cara\n  de asustada.[/page]";
global.msg_esp[6] = "[character,alaska,smug][owsprite,alaska,up][delay,1]* Asustate si quieres.[/page]";
global.msg_esp[7] = "[character,alaska,smug][delay,1]* No cambia el rollo\n  de que haya un tío\n  muerto allí.[/page]";
global.msg_esp[8] = "[character,chai,rolleyes][delay,1]* ...[/page]";
global.msg_esp[9] = "[character,chai,scared][owsprite,chai,scared][delay,1]* ¿En serio?[/page]";
global.msg_esp[10] = "[character,destiny,smile][owsprite,destiny,right][owsprite,destiny,smile][destinymove][delay,1]* ¿Estás en serio?[/page]";
global.msg_esp[11] = "[character,alaska,smug][owsprite,alaska,smug][delay,1]* Si no lo estoy,[freeze][delay,333][continue] que me\n  maten.[freeze][delay,333][continue]\n* Como al tío.[/page]";
global.msg_esp[12] = "[character,kaitlyn,neutral][owsprite,chai,left][owsprite,chai,normal][delay,1]* De hecho,[freeze][delay,333][continue] yo lo ví\n  en las noticias esta\n  mañana.[/page]";
global.msg_esp[13] = "[character,destiny,smile][owsprite,destiny,down][delay,1]* Espera,[freeze][delay,333][continue] ¿tú lo sabías?[/page]";
global.msg_esp[14] = "[character,kaitlyn,neutral][owsprite,kaitlyn,up][delay,1]* Seh.[/page]";
global.msg_esp[15] = "[character,kaitlyn,neutral][delay,1]* Sigo preocupada de\n  que algún rarito\n  encuentre el lugar.[/page]";
global.msg_esp[16] = "[character,chai,scared][owsprite,kaitlyn,normal][owsprite,destiny,right][owsprite,destiny,normal][owsprite,chai,scared][delay,1]* ¡Pues parece que ya\n  se han enterado![greenroomadvance1]";
instance_create_depth(x, y, -1000, obj_textboxNEW);
