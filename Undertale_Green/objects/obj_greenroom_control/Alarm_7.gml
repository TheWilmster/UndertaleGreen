global.msg[0] = "[character,gray,angry][delay,1]* Hey.[freeze][delay,333][continue]\n* Chai.[/page]";
global.msg[1] = "[character,chai,disappointed][delay,1]* What?[/page]";
global.msg[2] = "[character,gray,angry][delay,1]* Why did you ditch\n  Olive at practice\n  today?[/page]";
global.msg[3] = "[character,chai,disappointed][delay,1]* Why is this your\n  issue?[/page]";
global.msg[4] = "[character,gray,angry][delay,1]* It became my issue when\n  I had to babysit them\n  for an hour.[/page]";
global.msg[5] = "[character,gray,angry][delay,1]* What,[freeze][delay,333][continue] are you too cool\n  to be a sister?[/page]";
global.msg[6] = "[character,chai,sad][owsprite,chai,sad][delay,1]* ...[/page]";
global.msg[7] = "[character,destiny,angry][owsprite,gray_gr,otherleft][delay,1]* And what makes you\n  such an expert on\n  Chai's family life?[/page]";
global.msg[8] = "[character,destiny,angry][delay,1]* Have you ever even\n  met her?[/page]";
global.msg[9] = "[character,gray,angry][delay,1]* I met her very young\n  and afraid sibling.[/page]";
global.msg[10] = "[character,destiny,angry][delay,1]* And I bet you learned\n  so much from them.[/page]";
global.msg[11] = "[character,alaska,disappointed][owsprite,chai,normal][owsprite,gray_gr,right][delay,1]* Yeah chill out,[freeze][delay,333][continue] okay?[/page]";
global.msg[12] = "[character,alaska,disappointed][delay,1]* It's really not this\n  big of a deal.[/page]";
global.msg[13] = "[character,gray,angry][delay,1]* Eden over here had\n  to deal with your\n  vacation time as well.[/page]";
global.msg[14] = "[character,gray,angry][delay,1]* Isn't that right,[freeze][delay,333][continue] Eden?[/page]";
global.msg[15] = "[character,eden,buggin][edenscared][delay,1]* ...[/page]";
global.msg[16] = "[character,kaitlyn,neutral][owsprite,gray_gr,otherleft][delay,1]* Worry about your own\n  life,[freeze][delay,333][continue] 'kay?[/page]";
global.msg[17] = "[character,kaitlyn,neutral][delay,1]* Stop wasting space and\n  run off with little\n  miss nepotism.[/page]";
global.msg[18] = "[character,gray,angryright][owsprite,gray_gr,right][delay,1]* ...[freeze][delay,333][continue]Eden?[/page]";
global.msg[19] = "[character,eden,buggin][edenscared][delay,1]* ...[greenroomadvance4]";
global.msg_esp[0] = "[character,gray,angry][delay,1]* Ey.[freeze][delay,333][continue]\n* Chai.[/page]";
global.msg_esp[1] = "[character,chai,disappointed][delay,1]* ¿Qué?[/page]";
global.msg_esp[2] = "[character,gray,angry][delay,1]* ¿En qué momento se te\n  pasa por la cabeza \n  abandonar a Olive así?[/page]";
global.msg_esp[3] = "[character,chai,disappointed][delay,1]* ¿Por qué debería ser\n  esto tu problema?[/page]";
global.msg_esp[4] = "[character,gray,angry][delay,1]* Se volvió mi problema\n  cuando tuve que hacer de\n  niñero por una hora.[/page]";
global.msg_esp[5] = "[character,chai,sad][owsprite,chai,sad][delay,1]* ...[/page]";
global.msg_esp[6] = "[character,destiny,angry][owsprite,gray_gr,otherleft][delay,1]* ¿Y qué te hace ser tal\n  experto en la vida\n  de Chai?[/page]";
global.msg_esp[7] = "[character,destiny,angry][delay,1]* ¿Acaso os habéis llegado\n  a saludar jamás?[/page]";
global.msg_esp[8] = "[character,gray,angry][delay,1]* No,[freeze][delay,333][continue] pero conocí a otra\n  persona,[freeze][delay,333][continue] una persona\n  pequeña y asustada.[/page]";
global.msg_esp[9] = "[character,destiny,angry][delay,1]* Claro,[freeze][delay,333][continue] y Olive te dijo\n  todo sobre Chai,[freeze][delay,333][continue] seguro.[/page]";
global.msg_esp[10] = "[character,chai,angry][owsprite,chai,normal][owsprite,gray_gr,right][delay,1]* Anda,[freeze][delay,333][continue] tranquilízate,\n[freeze][delay,333][continue]  ¿va?[/page]";
global.msg_esp[11] = "[character,chai,angry][delay,1]* Tampoco es un mundo para\n  lo que estás montando.[/page]";
global.msg_esp[12] = "[character,gray,angry][delay,1]* Eden también tuvo que\n  preocuparse de Olive\n  mientras estabas de...[/page]";
global.msg_esp[13] = "[character,gray,angry][delay,1]* ...vacaciones.[/page]";
global.msg_esp[14] = "[character,gray,angry][delay,1]* ¿Verdad,[freeze][delay,333][continue] Eden?[/page]";
global.msg_esp[15] = "[character,eden,buggin][edenscared][delay,1]* ...[/page]";
global.msg_esp[16] = "[character,kaitlyn,neutral][owsprite,gray_gr,otherleft][delay,1]* ¿Por qué no te preocupas\n  de tu propia vida?,\n[freeze][delay,333][continue]  ¿estamos?[/page]";
global.msg_esp[17] = "[character,kaitlyn,neutral][delay,1]* Deja de malgastar\n  oxígeno y vete ya con tu\n  señorita nepotismo.[/page]";
global.msg_esp[18] = "[character,gray,angryright][owsprite,gray_gr,right][delay,1]* ...[freeze][delay,333][continue]¿Eden?[/page]";
global.msg_esp[19] = "[character,eden,buggin][edenscared][delay,1]* ...[greenroomadvance4]";
instance_create_depth(x, y, -1000, obj_textboxNEW);
