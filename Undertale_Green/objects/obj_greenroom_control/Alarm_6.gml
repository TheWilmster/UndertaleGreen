global.msg[0] = "[character,eden,lockedin][delay,1]* Can you believe her?[/page]";
global.msg[1] = "[character,gray,occupied][owsprite,chai,normal][owsprite,alaska,normal][delay,1]* No,[freeze][delay,333][continue] that's crazy.[/page]";
global.msg[2] = "[character,eden,lockedin][delay,1]* Do you know what I'm\n  talking about?[/page]";
global.msg[3] = "[character,gray,occupied][delay,1]* Yeah no you're so\n  right.[/page]";
global.msg[4] = "[character,eden,yelling][delay,1][owsprite,gray_gr,surprised][greenroomadvance3]* GRAYMORE![/page]";
global.msg[5] = "[character,gray,surprised][delay,1]* Not so loud,[freeze][delay,333][continue] okay?[/page]";
global.msg[6] = "[character,eden,upset][delay,1]* Sorry,[freeze][delay,333][continue] I'm just a\n  little upset right now.[/page]";
global.msg[7] = "[character,gray,smug][delay,1][owsprite,gray_gr,default]* What,[freeze][delay,333][continue] is it your dad?[/page]";
global.msg[8] = "[character,gray,smug][owsprite,gray_gr,happy][delay,1]* I mean I totally get it\n  that man can't direct\n  his own life much less...[/page]";
global.msg[9] = "[character,eden,lockedin][delay,1]* I cant believe Chai\n  abandoned her little\n  sibling at rehearsal![/page]";
global.msg[10] = "[character,eden,lockedin][delay,1]* I enjoyed playing with\n  them,[freeze][delay,333][continue] but it's not\n  our responsibility![/page]";
global.msg[11] = "[character,gray,inquisite][owsprite,gray_gr,default][delay,1]* ...[freeze][delay,333][continue]You're serious?[/page]";
global.msg[12] = "[character,eden,lockedin][delay,1]* Yes I'm serious!\n[freeze][delay,333][continue]* Olive seems like a very\n  nice kid.[/page]";
global.msg[13] = "[character,eden,upset][delay,1]* They deserve better than\n  Chai and her pit punks![/page]";
global.msg[14] = "[character,gray,angry][owsprite,gray_gr,mad][delay,1]* ...[/page]";
global.msg[15] = "[character,eden,buggin][delay,1]* Gray don't...![greenroomadvance2]";
global.msg_esp[0] = "[character,eden,lockedin][delay,1]* ¿Te la puedes creer?[/page]";
global.msg_esp[1] = "[character,gray,occupied][owsprite,chai,normal][owsprite,alaska,normal][delay,1]* No,[freeze][delay,333][continue] es de locos.[/page]";
global.msg_esp[2] = "[character,eden,lockedin][delay,1]* ¿Sabes acaso lo que te\n  estoy diciendo?[/page]";
global.msg_esp[3] = "[character,gray,occupied][delay,1]* claro,[freeze][delay,333][continue] claro,[freeze][delay,333][continue] tienes\n  toda la razón.[/page]";
global.msg_esp[4] = "[character,eden,yelling][delay,1][owsprite,gray_gr,surprised][greenroomadvance3]* ¡GRAYMORE![/page]";
global.msg_esp[5] = "[character,gray,surprised][delay,1]* No grites,[freeze][delay,333][continue] ¿vale?[/page]";
global.msg_esp[6] = "[character,eden,upset][delay,1]* Lo siento,[freeze][delay,333][continue] estoy tan\n  solo un poquito\n  enfadada.[/page]";
global.msg_esp[7] = "[character,gray,smug][delay,1][owsprite,gray_gr,default]* ¿Un poquito?[/page]";
global.msg_esp[8] = "[character,gray,smug][owsprite,gray_gr,happy][delay,1]* ¿Qué pasa?,[freeze][delay,333][continue] ¿acaso\n  alguien ha quemado tu\n  casa,[freeze][delay,333][continue] o algo?[/page]";
global.msg_esp[9] = "[character,eden,lockedin][delay,1]* No me cabe en la cabeza\n  que Chai abandonara\n  a Olive...[/page]";
global.msg_esp[10] = "[character,eden,lockedin][delay,1]* ...Durante todo el\n  ensayo.[/page]";
global.msg_esp[11] = "[character,eden,lockedin][delay,1]* Me ha entretenido jugar\n  a las batallitas,[freeze][delay,333][continue] ¡pero\n  no es nuestra...[/page]";
global.msg_esp[12] = "[character,eden,lockedin][delay,1]* ...responsabilidad![/page]";
global.msg_esp[13] = "[character,gray,inquisite][owsprite,gray_gr,default][delay,1]* ...[freeze][delay,333][continue]¿Vas en serio?[/page]";
global.msg_esp[14] = "[character,eden,lockedin][delay,1]* ¡Sí, voy en serio!\n[freeze][delay,333][continue]* Olive no parece merecer\n  esto.[/page]";
global.msg_esp[15] = "[character,eden,upset][delay,1]* Se merece algo mejor\n  que Chai y su sindicato\n  del mal.[/page]";
global.msg_esp[16] = "[character,gray,angry][owsprite,gray_gr,mad][delay,1]* ...[greenroomadvance2]";
instance_create_depth(x, y, -1000, obj_textboxNEW);
