global.msg[0] = "[character,alaska,smug][delay,1]* Did anyone bring,\n[freeze][delay,333][continue]  like,[freeze][delay,333][continue] a speaker or\n  something?[/page]";
global.msg[1] = "[character,destiny,smug][delay,1]* I thought Chai was\n  going to.[/page]";
global.msg[2] = "[character,chai,neutral][delay,1]* Oh,[freeze][delay,333][continue] yeah.[freeze][delay,333][continue] I did.[/page]";
global.msg[3] = "[character,destiny,smile][delay,1]* Are you gonna play\n  your new song for us\n  tonight?[/page]";
global.msg[4] = "[character,chai,scared][delay,1]* Destiny![/page]";
global.msg[5] = "[character,alaska,happy][delay,1]* You make music?[/page]";
global.msg[6] = "[character,kaitlyn,smug][delay,1][turnoff]* Okay we are like,[freeze][delay,333][continue]\n  dropping everything\n  until we hear this.[/page]";
global.msg[7] = "[character,destiny,ashamed][delay,1]* My bad.[/page]";
global.msg[8] = "[character,alaska,happy][delay,1]* Can we play it in\n  the car?[/page]";
global.msg[9] = "[character,chai,remorseful][delay,1]* No it's...[freeze][delay,333][continue]\n* It's not finished.[/page]";
global.msg[10] = "[character,kaitlyn,smile][delay,1]* Even better.[/page]";
global.msg[11] = "[character,chai,remorseful][delay,1]* It's not even\n  recorded yet.[/page]";
global.msg[12] = "[character,chai,remorseful][delay,1]* It's just on my\n  guitar.[/page]";
global.msg[13] = "[character,alaska,happy][delay,1]* Do you have it with\n  you?[/page]";
global.msg[14] = "[character,chai,scared][delay,1]* I...[/page]";
global.msg[15] = "[character,kaitlyn,smile][delay,1]* Oh my god no wait she\n  totally does.[/page]";
global.msg[16] = "[character,kaitlyn,smile][delay,1]* I saw it in the trunk.[/page]";
global.msg[17] = "[character,alaska,happy][delay,1]* Sing for us![freeze][delay,333][continue]\n* Sing for us![/page]";
global.msg[18] = "[character,destiny,ashamed][delay,1]* Sorry,[freeze][delay,333][continue] girl.[freeze][delay,333][continue]\n* They'll forget about it\n  once we break in.[/page]";
global.msg[19] = "[character,chai,remorseful][delay,1]* ...[freeze][delay,333][continue]You sure?[/page]";
global.msg[20] = "[character,alaska,happy][delay,1]* No we won't!\n[freeze][delay,333][continue]* No we won't![officeparking]";
global.msg_esp[0] = "[character,alaska,smug][delay,1]* ¿Ha traido alguna,\n[freeze][delay,333][continue]  en plan,[freeze][delay,333][continue] un altavoz\n  o algo?[/page]";
global.msg_esp[1] = "[character,destiny,smug][delay,1]* Pensaba que Chai\n  era la encargada.[/page]";
global.msg_esp[2] = "[character,chai,neutral][delay,1]* Ah,[freeze][delay,333][continue] sí.[freeze][delay,333][continue] Lo traje.[/page]";
global.msg_esp[3] = "[character,destiny,smile][delay,1]* ¿Vas a tocarnos tu\n  nueva canción esta\n  noche?[/page]";
global.msg_esp[4] = "[character,chai,scared][delay,1]* ¡Destiny![/page]";
global.msg_esp[5] = "[character,alaska,happy][delay,1]* ¿Compones música?[/page]";
global.msg_esp[6] = "[character,kaitlyn,smug][delay,1][turnoff]* Osea,[freeze][delay,333][continue] hasta que no\n  la escuchemos no\n  vamos a...[/page]";
global.msg_esp[7] = "[character,kaitlyn,smug][delay,1]* ...Seguir hablando.[/page]";
global.msg_esp[8] = "[character,destiny,ashamed][delay,1]* Mi culpa.[/page]";
global.msg_esp[9] = "[character,alaska,happy][delay,1]* ¿Puedes tocarla en\n  el coche?[/page]";
global.msg_esp[10] = "[character,chai,remorseful][delay,1]* No...[freeze][delay,333][continue]\n* No está terminada.[/page]";
global.msg_esp[11] = "[character,kaitlyn,smile][delay,1]* Mejor incluso.[/page]";
global.msg_esp[12] = "[character,chai,remorseful][delay,1]* Ni me ha dado\n  tiempo a grabarla.[/page]";
global.msg_esp[13] = "[character,chai,remorseful][delay,1]* Está solo\n  en mi guitarra.[/page]";
global.msg_esp[14] = "[character,alaska,happy][delay,1]* ¿La tienes aquí\n  contigo?[/page]";
global.msg_esp[15] = "[character,chai,scared][delay,1]* Yo...[/page]";
global.msg_esp[16] = "[character,kaitlyn,smile][delay,1]* Oh Dios mío sí\n  que la tiene.[/page]";
global.msg_esp[17] = "[character,kaitlyn,smile][delay,1]* La vi en el\n  maletero.[/page]";
global.msg_esp[18] = "[character,alaska,happy][delay,1]* ¡Canta,[freeze][delay,333][continue] Chai![freeze][delay,333][continue]\n* ¡Canta para nosotras![/page]";
global.msg_esp[19] = "[character,destiny,ashamed][delay,1]* Lo siento,[freeze][delay,333][continue] tía.[freeze][delay,333][continue]\n* Ya se olvidaran\n  cuando lleguemos.[/page]";
global.msg_esp[20] = "[character,chai,remorseful][delay,1]* ¿...[freeze][delay,333][continue]Segura?[/page]";
global.msg_esp[21] = "[character,alaska,happy][delay,1]* ¡No nos olvidaremos!\n[freeze][delay,333][continue]* ¡No nos olvidaremos![officeparking]";
