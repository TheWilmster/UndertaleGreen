global.msg[0] = "[character,alaska,happyFB][delay,1]* Alright,[freeze][delay,333][continue] are you girls\n  ready?[/page]";
global.msg[1] = "[character,alaska,happyFB][delay,1]* I have a true story\n  for you all tonight.[/page]";
global.msg[2] = "[character,destiny,smugFB][delay,1]* Don't you have a\n  true story every time?[/page]";
global.msg[3] = "[character,chai,happyFB][delay,1]* Yeah,[freeze][delay,333][continue] and last time it\n  ended with someone being\n  eaten by a zombie.[/page]";
global.msg[4] = "[character,alaska,smugFB][delay,1]* First of all,[freeze][delay,333][continue] that\n  did happen.[freeze][delay,333][continue] You're just\n  closed-minded.[/page]";
global.msg[5] = "[character,alaska,smugFB][delay,1]* And second of all,[freeze][delay,333][continue]\n  this one really is\n  a Middlewater legend.[/page]";
global.msg[6] = "[character,alaska,smugFB][delay,1]* In fact,[freeze][delay,333][continue] it's about\n  the cave we're in\n  right now...[/page]";
global.msg[7] = "[character,alaska,lookleftFB][delay,1]* See,[freeze][delay,333][continue] there's been tales\n  about monsters living on\n  Ebott for decades.[/page]";
global.msg[8] = "[character,alaska,lookrightFB][delay,1]* And one night long\n  ago,[freeze][delay,333][continue] a kid found out\n  they were true.[/page]";
global.msg[9] = "[character,alaska,normalFB][delay,1]*[stormstart] A storm began to rip\n  into Middlewater with\n  no signs of stopping.[/page]";
global.msg[10] = "[character,alaska,normalFB][delay,1]* Everyone had already\n  huddled up inside to\n  wait it out.[/page]";
global.msg[11] = "[character,alaska,normalFB][delay,1]* That is,[freeze][delay,333][continue] everyone except\n  one.[/page]";
global.msg[12] = "[character,alaska,normalFB][delay,1]* A kid had been\n  playing up on Ebott\n  before the storm hit.[/page]";
global.msg[13] = "[character,alaska,normalFB][delay,1]* By the time it struck,\n[freeze][delay,333][continue]  it was already too\n  late.[/page]";
global.msg[14] = "[character,alaska,normalFB][delay,1]* Mountain paths turned\n  into floodplains.[freeze][delay,333][continue]\n* Branches into whips.[/page]";
global.msg[15] = "[character,alaska,normalFB][delay,1]* Desperate for refuge,[freeze][delay,333][continue]\n  [stormpickup]the kid ran into a\n  cave.[/page]";
global.msg[16] = "[character,chai,concernedFB][delay,1]* Hey,[freeze][delay,333][continue] is anyone concerned\n  about the actual storm\n  picking up outside?[/page]";
global.msg[17] = "[character,destiny,smileFB][delay,1]* I'm more concerned\n  about how good this\n  story is.[/page]";
global.msg[18] = "[character,alaska,smugFB][delay,1]* With no light or\n  food,[freeze][delay,333][continue] the kid had to\n  wait out the storm.[/page]";
global.msg[19] = "[character,alaska,smugFB][delay,1]* Terror turned to\n  boredom,[freeze][delay,333][continue] and boredom\n  turned to comfort.[/page]";
global.msg[20] = "[character,alaska,normalFB][delay,1]* That is,[freeze][delay,333][continue] until a voice\n  rang out.[/page]";
global.msg[21] = "[character,alaska,normalFB][delay,1]* Someone was yelling\n  for them.[/page]";
global.msg[22] = "[character,alaska,normalFB][delay,1]* Most of the voice's\n  words were dampened by\n  the raging storm.[/page]";
global.msg[23] = "[character,alaska,normalFB][delay,1]* But words didn't\n  matter to the kid.[/page]";
global.msg[24] = "[character,alaska,normalFB][delay,1]* The voice's tone was\n  more than enough.[/page]";
global.msg[25] = "[character,alaska,normalFB][delay,1]* It wasn't help.[freeze][delay,333][continue]\n* The voice was far too\n  bitter for that.[/page]";
global.msg[26] = "[character,alaska,normalFB][delay,1]* It sounded like rage.[freeze][delay,333][continue]\n* It sounded like hatred.[/page]";
global.msg[27] = "[character,alaska,normalFB][delay,1]* The voice came from\n  deep within the cave.[/page]";
global.msg[28] = "[character,alaska,normalFB][delay,1]* Deeper than the\n  kid thought was\n  possible.[/page]";
global.msg[29] = "[character,alaska,normalFB][delay,1]* They patted the ground\n  until there wasn't\n  any ground left.[/page]";
global.msg[30] = "[character,alaska,normalFB][delay,1]* There was a pit in the\n  center of the cave.[/page]";
global.msg[31] = "[character,alaska,normalFB][delay,1]* The kid peered over\n  the edge.[/page]";
global.msg[32] = "[character,alaska,normalFB][delay,1]* Against all odds,[freeze][delay,333][continue] a\n  faint light shone from\n  within.[/page]";
global.msg[33] = "[character,alaska,normalFB][delay,1]* The voice became more\n  ferocious,[freeze][delay,333][continue] rising louder\n  and louder until...[fireout]";
instance_create_depth(x, y, -1000, obj_textboxNEW);
