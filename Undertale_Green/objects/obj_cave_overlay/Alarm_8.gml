global.msg[0] = "[character,alaska,concernedFB][delay,1]* You alright?[/page]";
global.msg[1] = "[character,destiny,spookedFB][delay,1]* No.[freeze][delay,333][continue]\n* But I will be.[/page]";
global.msg[2] = "[character,kaitlyn,neutralFB][delay,1]* Hey,[freeze][delay,333][continue] is there something\n  written on the hole?[/page]";
global.msg[3] = "[character,alaska,angryFB][delay,1]* Hey,[freeze][delay,333][continue] how about you\n  read the room?[freeze][delay,333][continue]\n* Destiny almost died.[/page]";
global.msg[4] = "[character,kaitlyn,empatheticFB][delay,1]* I'm serious![freeze][delay,333][continue]\n* There's something\n  written there.[skycleaver]";
