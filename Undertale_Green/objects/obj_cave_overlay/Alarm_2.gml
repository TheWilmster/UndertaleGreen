global.msg[0] = "[character,kaitlyn,terrorFB][delay,1]* AHH!!![/page]";
global.msg[1] = "[character,destiny,scaredFB][delay,1]* Kaitlyn,[freeze][delay,333][continue] was that you?[/page]";
global.msg[2] = "[character,kaitlyn,neutralFB][delay,1]* I think it was Chai.[/page]";
global.msg[3] = "[character,chai,scaredFB][delay,1]* Me?[/page]";
global.msg[4] = "[character,destiny,yesmaamFB][delay,1]* We all know it was\n  you,[freeze][delay,333][continue] Katilyn.[/page]";
global.msg[5] = "[character,kaitlyn,neutralFB][delay,1]* Can we maybe focus\n  on like,[freeze][delay,333][continue] the horrible\n  situation we're in?[/page]";
global.msg[6] = "[character,destiny,scaredFB][delay,1]* Okay chill out,[freeze][delay,333][continue] let's\n  just make our way to\n  the entrance.[treefall]";
