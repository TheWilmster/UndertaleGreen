global.msg[0] = "[character,none,-1][delay,1]* He-LLO?[delay,333] Do you mind?[delay,333]\n* Some of us are busy making ART![/page]";
global.msg[1] = "[character,none,-1][delay,1]* I am NOT a part of this\n  'performance',[delay,333] thank you very\n  MUCH![/page]";
global.msg[2] = "[character,none,-1][delay,1]* 'ACTING' is the death of art![delay,333]\n* I photograph LIFE!![/page]";
global.msg[3] = "[character,none,-1][delay,1]* (You tell her to take the lens\n  cap off.)";
global.msg_esp[0] = "[character,none,-1][delay,1]* ¿Ho-LA?[delay,333] ¿Te importaría?[delay,333]\n* ¡Algunos de nosotros nos preocupamos\n  por el arte que es la fotografía![/page]";
global.msg_esp[1] = "[character,none,-1][delay,1]* ¡NO soy parte de este 'teatro',[delay,333] MUCHAS gracias![/page]";
global.msg_esp[2] = "[character,none,-1][delay,1]* El actuar es la MUERTE del arte[delay,333]\n* ¡¡YO fotografío VIDA!![/page]";
global.msg_esp[3] = "[character,none,-1][delay,1]* (Le dices que tiene la tapa\n  puesta sobre la lente.)";
instance_create_depth(x, y, -1000, obj_textboxNEW);
