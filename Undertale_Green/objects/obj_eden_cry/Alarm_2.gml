global.msg[0] = "[character,eden,crysurprised][owsprite,eden,crysurp][delay,1]* Shoot![freeze][delay,333][continue]\n* I've gotta get going.[/page]";
global.msg[1] = "[character,eden,crysurprised][delay,1]* Gray's gonna be at\n  my house any minute\n  now.[/page]";
global.msg[2] = "[character,eden,crysurprised][delay,1]* I'm so sorry about\n  my outburst here,[freeze][delay,333][continue] Olive.[/page]";
global.msg[3] = "[character,eden,crysurprised][delay,1]* I promise I'll make it\n  up to you.[/page]";
global.msg[4] = "[character,eden,crysmile][owsprite,eden,crysmile][delay,1]* Maybe we can draw\n  together.[freeze][delay,333][continue]\n* That could be fun.[/page]";
global.msg[5] = "[character,eden,crysmile][delay,1]* Also maybe don't tell\n  your sister.[freeze][delay,333][continue]\n* If you could.[/page]";
global.msg[6] = "[character,eden,crysmile][delay,1]* See you![edenleaveschool]";
instance_create_depth(x, y, -1000, obj_textboxNEW);
