global.msg[2] = "[character,eden,crysmile][owsprite,eden,crysmile][delay,1]* Hi Olive.[/page]";
global.msg[3] = "[character,eden,cryswallow][owsprite,eden,cryblink][delay,1]* ...[/page]";
global.msg[4] = "[character,eden,crycurious][owsprite,eden,crynorm][delay,1]* Why hasn't your sister\n  taken you home?[/page]";
global.msg[5] = "[character,eden,crymad][owsprite,eden,cryangry][delay,1]* Did she leave without\n  you?[/page]";
