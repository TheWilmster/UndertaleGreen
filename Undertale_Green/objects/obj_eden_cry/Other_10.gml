global.msg[8] = "[character,eden,cryswallow][owsprite,eden,cryblink][delay,1]* Olive...[/page]";
global.msg[9] = "[character,eden,crysmile][owsprite,eden,crysmile][delay,1]* You should...[freeze][delay,333][continue] go see\n  your sister.[/page]";
global.msg[10] = "[character,eden,crysmile][delay,1]* I don't want to keep\n  you.[/page]";
