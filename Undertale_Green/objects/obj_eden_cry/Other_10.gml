global.msg[12] = "[character,eden,cryuneasy][owsprite,eden,crynorm][delay,1]* No it's...[freeze][delay,333][continue] it's stupid.[/page]";
global.msg[13] = "[character,eden,cryuneasy][delay,1]* ...[/page]";
global.msg[14] = "[character,eden,crydisappointed][delay,1]* It's my boyfriend.[/page]";
global.msg[15] = "[character,eden,crydisappointed][delay,1]* Well,[freeze][delay,333][continue] maybe it is.[/page]";
global.msg[16] = "[character,eden,crydisappointed][delay,1]* I got him a surprise\n  for tonight,[freeze][delay,333][continue] but...[/page]";
global.msg[17] = "[character,eden,cryhalfsmile][owsprite,eden,crysmile][delay,1]* I mean,[freeze][delay,333][continue] he's amazing.[freeze][delay,333][continue]\n  Gray is everything I\n  ever wanted.[/page]";
global.msg[18] = "[character,eden,cryhalfsmile][delay,1]* He's funny,[freeze][delay,333][continue] he's nice,[freeze][delay,333][continue]\n  he's so romantic...[/page]";
global.msg[19] = "[character,eden,crycurious][owsprite,eden,crynorm][delay,1]* But...[/page]";
global.msg[20] = "[character,eden,crycurious][delay,1]* It's just like...[/page]";
global.msg[21] = "[character,eden,crydisappointed][delay,1]* Every time I'm with\n  him...[/page]";
