global.msg[0] = "[character,shifty,shifty][delay,1]* At this point Nic\n  could open a buisness\n  with all that remodeling.[/page]";
global.msg[1] = "[character,shifty,shifty][delay,1]* Whaddya think?[freeze][delay,333][continue]\n* Pretty great, right?[/page]";
global.msg[2] = "[character,shifty,buggin][delay,1]* Right?[/page]";
global.msg[3] = "[character,shifty,normal][delay,1]* Well no matter what ya\n  think you'll at least be\n  happy to hear this.[/page]";
global.msg[4] = "[character,shifty,normal][delay,1]* The battle system in the\n  Pre-Show is gonna\n  change for the main game.[/page]";
global.msg[5] = "[character,shifty,normal][delay,1]* Seems like the devs\n  wanted to keep things\n  simple for the prequel.[/page]";
global.msg[6] = "[character,shifty,tweakin][delay,1]* Wouldn't expect anything\n  else from those two.[/page]";
global.msg[7] = "[character,shifty,normal][delay,1]* Before the devs catch\n  up to me I got a few\n  more points to go over.[/page]";
global.msg[8] = "[character,shifty,normal][delay,1]* How about we do a little\n  lightning round?[freeze][delay,333][continue] Bit of\n  lightning never hurt.[/page]";
global.msg[9] = "[character,shifty,tweakin][delay,1]* Unless you stand under\n  a tree in a field.[/page]";
global.msg[10] = "[character,shifty,cry][delay,1]* I'll never forget you,[freeze][delay,333][continue]\n  John.[/page]";
global.msg[11] = "[character,shifty,cry][delay,1]* ...[/page]";
global.msg[12] = "[character,shifty,normal][delay,1]* Alright,[freeze][delay,333][continue] let's start\n  with the game's\n  progress.[/page]";
global.msg[13] = "[character,shifty,normal][delay,1]* From what I've seen,[freeze][delay,333][continue]\n  it looks like the\n  game's writing is done.[/page]";
global.msg[14] = "[character,shifty,shifty][delay,1]* As in done done.[/page]";
global.msg[15] = "[character,shifty,normal][delay,1]* Seems like the devs only\n  have one more song to\n  make too.[/page]";
global.msg[16] = "[character,shifty,normal][delay,1]* If I'm doin' my math\n  right,[freeze][delay,333][continue] that makes over\n  sixteen tracks.[/page]";
global.msg[17] = "[character,shifty,normal][delay,1]* On the technical side\n  of things,[freeze][delay,333][continue] looks like\n  coding's going real well.[/page]";
global.msg[18] = "[character,shifty,normal][delay,1]* All things considered,[freeze][delay,333][continue]\n  I'm feeling confident\n  with a release date in...[/page]";
global.msg[19] = "[character,none,-1][delay,1]* Are you promising a release\n  date without our permission?[/page]";
global.msg[20] = "[character,shifty,buggin][delay,1]* That's my cue![/page]";
global.msg[21] = "[character,shifty,tweakin][delay,1]* All I can say is the\n  2025 release they\n  promised is still right.[/page]";
global.msg[22] = "[character,shifty,shifty][delay,1]* Expect some big things\n  soon,[freeze][delay,333][continue] and I'll expect\n  some bigger Gs next time.[/page]";
global.msg[23] = "[character,shifty,cry][delay,1]* I'll never forget you,[freeze][delay,333][continue]\n  Bob.[/page]";
global.msg[24] = "[character,shifty,cry][delay,1]* ...[/page]";
instance_create_depth(x, y, -1000, obj_textboxNEW);
