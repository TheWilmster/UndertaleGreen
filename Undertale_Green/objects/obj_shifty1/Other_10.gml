global.msg[0] = "[character,shifty,normal][delay,1]* Hey th...[/page]";
global.msg[1] = "[character,shifty,normal][delay,1]* ...[/page]";
global.msg[2] = "[character,shifty,evil][delay,1]* Hold on a sec.[/page]";
global.msg[3] = "[character,shifty,normal][delay,1]* Hey there.[/page]";
global.msg[4] = "[character,shifty,normal][delay,1]* I think I just about\n  outran those devs.[/page]";
global.msg[5] = "[character,shifty,evil][delay,1]* Let me tell ya,[freeze][delay,333][continue] those\n  boys are relentless.[/page]";
global.msg[6] = "[character,shifty,shifty][delay,1]* Wish they were that\n  dedicated to finishing\n  the game,[freeze][delay,333][continue] am I right?[/page]";
global.msg[7] = "[character,shifty,normal][delay,1]* ...[/page]";
global.msg[8] = "[character,shifty,normal][delay,1]* Is it hot in here?[/page]";
global.msg[9] = "[character,shifty,evil][delay,1]* I'm sweatin' like a\n  salesman with a lie\n  detector.[/page]";
global.msg[10] = "[character,none,-1][delay,1]* (You tell him he should take\n  his coat off.)[/page]";
global.msg[11] = "[character,shifty,tweakin][delay,1]* So you can run off\n  with it?[freeze][delay,333][continue]\n* Not a chance.[/page]";
global.msg[12] = "[character,shifty,normal][delay,1]* Matter of fact,[freeze][delay,333][continue] if\n  you want anything\n  outta me...[/page]";
global.msg[13] = "[character,shifty,normal][delay,1]* I've gotta see some\n  Gs first.[freeze][delay,333][continue]\n* Let's say 30G.[/page]";
global.msg[14] = "[character,shifty,shifty][delay,1]* Nothing wrong with\n  30G between friends.[/page]";
global.msg[15] = "[character,none,-1][delay,1]* (You tell him you'll send the\n  devs his location.)[/page]";
global.msg[16] = "[character,shifty,normal][delay,1]* Nice try buddy.[freeze][delay,333][continue]\n* You don't even know\n  where I am.[/page]";
global.msg[17] = "[character,shifty,normal][delay,1]* ...[/page]";
global.msg[18] = "[character,shifty,buggin][delay,1]* Right?[/page]";
global.msg[19] = "[character,shifty,tweakin][delay,1]* Fine.[freeze][delay,333][continue]\n* Ya got me.[freeze][delay,333][continue]\n* Let's get into it.[/page]";
global.msg[20] = "[character,shifty,normal][delay,1]* You remember this clip\n  show I put together?[/page]";
global.msg[21] = "[character,shifty,normal][delay,1]* Well it's changed.[freeze][delay,333][continue]\n* A lot.[/page]";
global.msg[22] = "[character,shifty,normal][delay,1]* At this point Nic\n  could build five schools'\n  worth of iterations.[/page]";
global.msg[23] = "[character,shifty,normal][delay,1]* Think I snuck the\n  most recent version\n  though...[/page]";
global.msg[24] = "[character,shifty,normal][delay,1]* So here's what that\n  teaser would look like\n  now.[/page]";
global.msg[25] = "[character,shifty,shifty][delay,1]* What'd ya think?[freeze][delay,333][continue]\n* Fresh coat of paint\n  never hurt anyone.[/page]";
global.msg[26] = "[character,shifty,evil][delay,1]* Unless you stick\n  around for too long.[/page]";
global.msg[27] = "[character,shifty,evil][delay,1]* I'll never forget you,[freeze][delay,333][continue]\n  Bob.[/page]";
global.msg[28] = "[character,shifty,normal][delay,1]* ...[/page]";
global.msg[29] = "[character,shifty,shifty][delay,1]* Oh yeah![/page]";
global.msg[30] = "[character,shifty,shifty][delay,1]* Forgot I had something\n  pretty nifty to show\n  off to ya.[/page]";
instance_create_depth(x, y, -1000, obj_textboxNEW);
