global.msg[0] = "[character,chai,disappointed][delay,1]* Mom said I gotta take\n  you to play practice\n  tomorrow.[/page]";
global.msg[1] = "[character,chai,neutral][delay,1]* Apparently she's too\n  busy to look after you.[/page]";
global.msg[2] = "[character,chai,neutral][delay,1][trailercont5]* I mean she better be if\n  she's making me go up to\n  Ebott this much.[/page]";
global.msg[3] = "[character,chai,neutral][delay,1]* I'll pick you up after\n  school.[/page][trailercont2]";
global.msg[4] = "[character,chai,disappointed][delay,1]* Bring your chess pieces\n  if you need them.[trailercont2]";
