global.msg[0] = "[character,chai,-1][delay,1]* Why do you insist on carrying\n  those things around?[/page]";
global.msg[1] = "[character,chai,-1][delay,1]* No other kid I know plays with\n  chess pieces.[/page]";
global.msg[2] = "[character,chai,-1][delay,1]* It's embarrassing.[beat1]";
global.msg_esp[0] = "[character,chai,-1][delay,1]* Por qué insistes en llevarte\n  ¿esas cosas a todos lados?[/page]";
global.msg_esp[1] = "[character,chai,-1][delay,1]* Ningún otro niño que conozca\n  juega con piezas de ajedrez.[/page]";
global.msg_esp[2] = "[character,chai,-1][delay,1]* Es raro.[beat1]";
