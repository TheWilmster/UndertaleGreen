global.msg[0] = "[character,destiny,nervousFB][owsprite,destiny,fb1][delay,1]* Shouldn't you grab some\n  fruits while you're up\n  here?[/page]";
global.msg[1] = "[character,chai,unsureFB][delay,1]* I guess it wouldn't\n  hurt.[/page]";
global.msg[2] = "[character,alaska,smugFB][delay,1]* It would hurt me,[freeze][delay,333][continue]\n  okay?[/page]";
global.msg[3] = "[character,alaska,smugFB][delay,1]* Your mom isn't gonna\n  die if she doesn't get\n  her ingredients today.[/page]";
global.msg[4] = "[character,alaska,smugFB][delay,1]* Tonight is for partying\n  and scary stories\n  only.[/page]";
global.msg[5] = "[character,kaitlyn,neutralFB][delay,1]* Oh joy.[/page]";
global.msg[6] = "[character,alaska,smugFB][delay,1]* And if you don't\n  like it,[freeze][delay,333][continue] the exit's\n  out that way.[/page]";
global.msg[7] = "[character,destiny,smugFB][owsprite,destiny,fb3][delay,1]* Which way?[/page]";
global.msg[8] = "[character,alaska,smugFB][delay,1]* The way we entered\n  from.[/page]";
global.msg[9] = "[character,destiny,smugFB][delay,1]* Point to it.[/page]";
global.msg[10] = "[character,alaska,smugFB][delay,1]* I can't.[freeze][delay,333][continue]\n* Hurt my arm earlier.[/page]";
global.msg[11] = "[character,destiny,smugFB][delay,1]* You're so lucky we\n  have Chai here.[/page]";
global.msg[12] = "[character,destiny,smugFB][delay,1]* I don't think you\n  would've found Ebott in\n  the first place.[/page]";
global.msg[13] = "[character,kaitlyn,smugFB][owsprite,kaitlyn,fb1][delay,1]* Bet you could find\n  your way out of\n  another relationship.[/page]";
global.msg[14] = "[character,alaska,smugFB][delay,1]* Bet you could't find\n  your way INTO a\n  relationship.[/page]";
global.msg[15] = "[character,kaitlyn,smugFB][delay,1]* Bet people only date\n  you because your\n  parents are rich.[/page]";
global.msg[16] = "[character,destiny,smugFB][delay,1]* Bet Chai hates her\n  job.[/page]";
global.msg[17] = "[character,chai,scaredFB][delay,1]* What did I do?[/page]";
global.msg[18] = "[character,destiny,smugFB][delay,1]* Just wanted to make\n  you feel included.[/page]";
global.msg[19] = "[character,alaska,happyFB][delay,1]* Alright![freeze][delay,333][continue]\n* Less talking and more\n  working.[/page]";
global.msg[20] = "[character,alaska,smugFB][delay,1]* We gotta get this\n  campfire going or the\n  cave will be too dark.[/page]";
global.msg[21] = "[character,destiny,smugFB][delay,1]* I feel like you're the\n  only one concerned\n  about that.[/page]";
global.msg[22] = "[character,kaitlyn,neutralFB][owsprite,kaitlyn,fb0][delay,1]* Yeah,[freeze][delay,333][continue] isn't it\n  supposed to be scary?[/page]";
global.msg[23] = "[character,alaska,neutralFB][delay,1]* There's a difference\n  between scared and\n  stupid.[/page]";
global.msg[24] = "[character,alaska,neutralFB][delay,1]* The cave has a massive\n  pit in it.[/page]";
global.msg[25] = "[character,chai,neutralFB][delay,1]* I'm with Alaska.[freeze][delay,333][continue]\n* Ebott is dangerous.[/page]";
global.msg[26] = "[character,destiny,neutralFB][owsprite,destiny,fb2][delay,1]* Fine,[freeze][delay,333][continue] fine.[/page]";
global.msg[27] = "[character,destiny,eyerollFB][delay,1]* If we're all gonna\n  be babies I might\n  as well join in.[/page]";
global.msg[28] = "[character,alaska,smugFB][delay,1]* Good to hear.[/page]";
global.msg[28] = "[character,alaska,happyFB][delay,1]* Everyone go get stuff\n  set up![/page]";
global.msg[29] = "[character,alaska,happyFB][delay,1]* I wanna start this\n  as soon as possible.[/page]";
global.msg[30] = "[character,destiny,yesmaamFB][owsprite,destiny,fb4][delay,1]* Yes,[freeze][delay,333][continue] ma'am![ebottwalkoff]";
global.msg_esp[0] = "[character,destiny,nervousFB][owsprite,destiny,fb1][delay,1]* ¿No deberías recolectar\n  algunas frutas ya\n  que estamos aquí?[/page]";
global.msg_esp[1] = "[character,chai,unsureFB][delay,1]* Supongo que no\n  hace daño.[/page]";
global.msg_esp[2] = "[character,alaska,smugFB][delay,1]* Pues a mí sí,[freeze][delay,333][continue]\n  ¿estamos?[/page]";
global.msg_esp[3] = "[character,alaska,smugFB][delay,1]* Tampoco es que tu\n  madre se muera si no\n  las llevas hoy.[/page]";
global.msg_esp[4] = "[character,alaska,smugFB][delay,1]* Sólo permitimos fiestas\n  e historias de miedo\n  esta noche.[/page]";
global.msg_esp[5] = "[character,kaitlyn,neutralFB][delay,1]* Qué bien.[/page]";
global.msg_esp[6] = "[character,alaska,smugFB][delay,1]* Y si no te gusta,\n[freeze][delay,333][continue]  tenéis la puerta\n  abierta para iros.[/page]";
global.msg_esp[7] = "[character,destiny,smugFB][owsprite,kaitlyn,fb3][delay,1]* ¿Por donde?[/page]";
global.msg_esp[8] = "[character,alaska,smugFB][delay,1]* Por donde hemos\n  llegado aquí.[/page]";
global.msg_esp[9] = "[character,destiny,smugFB][delay,1]* Dime por donde\n  con la mano.[/page]";
global.msg_esp[10] = "[character,alaska,smugFB][delay,1]* No puedo.[freeze][delay,333][continue]\n* Me hice daño en\n  la mano antes.[/page]";
global.msg_esp[11] = "[character,destiny,smugFB][delay,1]* Dale gracias a que\n  tenemos a Chai con\n  nosotras.[/page]";
global.msg_esp[12] = "[character,destiny,smugFB][delay,1]* No creo que hubieras\n  encontrado el monte\n  si quiera sin ella.[/page]";
global.msg_esp[13] = "[character,kaitlyn,smugFB][owsprite,kaitlyn,fb1][delay,1]* Ya,[freeze][delay,333][continue] estaría tan\n  perdida como tú\n  intentado encontrar...[/page]";
global.msg_esp[14] = "[character,kaitlyn,smugFB][delay,1]* ...una buen pareja.[/page]";
global.msg_esp[15] = "[character,alaska,smugFB][delay,1]* Y yo tan perdida\n  como tú intentando\n  encontrar alguna.[/page]";
global.msg_esp[16] = "[character,kaitlyn,smugFB][delay,1]* Me apuesto a que\n  sólo salen contigo\n  porque eres rica.[/page]";
global.msg_esp[17] = "[character,destiny,smugFB][delay,1]* Y yo a que Chai\n  odia su trabajo.[/page]";
global.msg_esp[18] = "[character,chai,scaredFB][delay,1]* ¿Y yo qué he hecho?[/page]";
global.msg_esp[19] = "[character,destiny,smugFB][delay,1]* Solo te queria\n  incluir en la\n  conversación.[/page]";
global.msg_esp[20] = "[character,alaska,happyFB][delay,1]* ¡Suficiente![freeze][delay,333][continue]\n* Menos hablar\n  y más trabajar.[/page]";
global.msg_esp[21] = "[character,alaska,smugFB][delay,1]* Tenemo que preparar\n  el fuego o si no se\n  nos pone la noche.[/page]";
global.msg_esp[22] = "[character,destiny,smugFB][delay,1]* Creo que eres la\n  única preocupada por\n  eso.[/page]";
global.msg_esp[23] = "[character,kaitlyn,neutralFB][owsprite,destiny,fb0][delay,1]* Eso,[freeze][delay,333][continue] ¿no se supone\n  que tiene que dar\n  miedo?[/page]";
global.msg_esp[24] = "[character,alaska,neutralFB][delay,1]* Hay diferencia\n  entre asustarse y\n  ser estúpido.[/page]";
global.msg_esp[25] = "[character,alaska,neutralFB][delay,1]* La cueva tiene un\n  hoyo masivo en\n  el centro.[/page]";
global.msg_esp[26] = "[character,chai,neutralFB][delay,1]* Estoy con Alaska.[freeze][delay,333][continue]\n* este monte me da\n  cosa,[freeze][delay,333][continue] es peligroso.[/page]";
global.msg_esp[27] = "[character,destiny,neutralFB][owsprite,destiny,fb2][delay,1]* Vale,[freeze][delay,333][continue] entiendo.[/page]";
global.msg_esp[28] = "[character,destiny,eyerollFB][delay,1]* Si vamos a ser\n  unas bebés pues me\n  tendré que sumar.[/page]";
global.msg_esp[29] = "[character,alaska,smugFB][delay,1]* No esperaba menos.[/page]";
global.msg_esp[30] = "[character,alaska,happyFB][delay,1]* ¡Vamos,[freeze][delay,333][continue] levantaos,\n[freeze][delay,333][continue]  vayamos a preparar\n  las cosas![/page]";
global.msg_esp[31] = "[character,alaska,happyFB][delay,1]* ¡Preparemos esto\n  lo antes posible![/page]";
global.msg_esp[32] = "[character,destiny,yesmaamFB][owsprite,destiny,fb4][delay,1]* ¡Sí,[freeze][delay,333][continue] señora![ebottwalkoff]";
instance_create_depth(x, y, -1000, obj_textboxNEW);
