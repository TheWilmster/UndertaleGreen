global.msg[0] = "[character,shifty,normal][delay,1]* I think that's about\n  all I got.[/page]";
global.msg[1] = "[character,shifty,tweakin][delay,1]* ...[freeze][delay,333][continue]At least without\n  any more Gs.[/page]";
global.msg[2] = "[character,shifty,normal][delay,1]* Would ya look at that.[/page]";
global.msg[3] = "[character,shifty,normal][delay,1]* Seems like I got one\n  more surprise.[/page]";
global.msg[4] = "[character,shifty,normal][delay,1]* Some of the main\n  characters are making\n  a call.[/page]";
global.msg[5] = "[character,shifty,tweakin][delay,1]* ...[/page]";
global.msg[6] = "[character,shifty,tweakin][delay,1]* Don't look at me like\n  that.[/page]";
global.msg[7] = "[character,shifty,tweakin][delay,1]* If you were worried\n  about ethics ya wouldn't\n  be here.[/page]";
global.msg[8] = "[character,shifty,evil][delay,1]* But uhh...[/page]";
global.msg[9] = "[character,shifty,tweakin][delay,1]* If anyone asks this\n  is totally legal.[/page]";
global.msg[10] = "[character,shifty,tweakin][delay,1]* Last I checked there's\n  nothin' against tapping\n  phone lines.[/page]";
global.msg[11] = "[character,shifty,normal][delay,1]* Looks like it's Eden\n  and her ol' ball and\n  chain.[/page]";
global.msg[12] = "[character,eden,neu][delay,1]* Hey sweetie,[freeze][delay,333][continue] is\n  something wrong?[freeze][delay,333][continue] It's\n  one in the morning.[/page]";
global.msg[13] = "[character,gray,-1][delay,1]* What was your dad doing here?[/page]";
global.msg[14] = "[character,eden,distressed][delay,1]* What?[/page]";
global.msg[15] = "[character,gray,-1][delay,1]* Me and the lads were playing\n  football on the pitch...[/page]";
global.msg[16] = "[character,eden,distressed][delay,1]* At the school?[/page]";
global.msg[17] = "[character,gray,-1][delay,1]* Possibly.[/page]";
global.msg[18] = "[character,eden,miffed][delay,1]* At one in the morning?[/page]";
global.msg[19] = "[character,gray,-1][delay,1]* Listen,[delay,333] we were playing\n  football at a reasonable\n  hour...[/page]";
global.msg[20] = "[character,gray,-1][delay,1]* And out of nowhere your dad\n  comes and tells us off.[/page]";
global.msg[21] = "[character,gray,-1][delay,1]* Did he put a tracker on me?[/page]";
global.msg[22] = "[character,gray,-1][delay,1]* Does he have a hidden camera\n  or something?[/page]";
global.msg[23] = "[character,gray,-1][delay,1]* Because honestly that that\n  would be way worse for you\n  than for me.[/page]";
global.msg[24] = "[character,eden,halfasleep][delay,1]* He's at my aunt's\n  tonight.[freeze][delay,333][continue] She lives next\n  to the school.[/page]";
global.msg[25] = "[character,eden,halfasleep][delay,1]* He probably just\n  happened to see you\n  out past curfew.[/page]";
global.msg[26] = "[character,gray,-1][delay,1]* You say that like I did\n  something wrong.[/page]";
global.msg[27] = "[character,eden,distressed][delay,1]* I did not![/page]";
global.msg[28] = "[character,gray,-1][delay,1]* Eden,[delay,333] the guy hates me![/page]";
global.msg[29] = "[character,gray,-1][delay,1]* Took weeks to convince him I\n  was good enough to take you\n  to the movies.[/page]";
global.msg[30] = "[character,gray,-1][delay,1]* With him sitting between us.[/page]";
global.msg[31] = "[character,eden,miffed][delay,1]* And you still reached\n  over him to steal my\n  popcorn.[/page]";
global.msg[32] = "[character,gray,-1][delay,1]* And I don't regret a thing.[/page]";
global.msg[33] = "[character,eden,happysleep][delay,1]* Speaking of regrets,[freeze][delay,333][continue] I\n  forgot to tell you![/page]";
global.msg[34] = "[character,eden,happysleep][delay,1]* I've been doing some\n  research for that\n  history club project.[/page]";
global.msg[35] = "[character,gray,-1][delay,1]* I'd love to hear...[delay,333]\n* That all sounds...[delay,333]\n* Go ahead![/page]";
global.msg[36] = "[character,eden,distressed][delay,1]* Hello?[freeze][delay,333][continue]\n* Think you might have\n  a bad connection.[/page]";
global.msg[37] = "[character,gray,-1][delay,1]* Sorry...[delay,333]\n* Going through a tunnel...[/page]";
global.msg[38] = "[character,eden,neu][delay,1]* You're still driving\n  home?[/page]";
global.msg[39] = "[character,gray,-1][delay,1]* Phone's dying...[delay,333]\n* Running out...[delay,333]\n* No data...[/page]";
global.msg[40] = "[character,eden,miffed][delay,1]* Really.[/page]";
global.msg[41] = "[character,gray,-1][delay,1]* Cat stole my phone...[delay,333]\n* Just hit a deer...[delay,333]\n* Gotta go...";
instance_create_depth(x, y, -1000, obj_textboxNEW);
