global.msg[0] = "[character,chai,neutral][delay,1]* I'm supposed to be\n  up on Ebott tonight.[/page]";
global.msg[1] = "[character,chai,rolleyes][delay,1]* And tomorrow.[/page]";
global.msg[2] = "[character,chai,angry][delay,1]* I mean,[freeze][delay,333][continue] who does mom\n  think she is?[/page]";
global.msg[3] = "[character,chai,angry][delay,1]* I work myself to\n  death at school.[/page]";
global.msg[4] = "[character,chai,angry][delay,1]* I help in the pit\n  all night.[/page]";
global.msg[5] = "[character,chai,angry][delay,1]* I clean up the house\n  before I go to bed.[/page]";
global.msg[6] = "[character,chai,angry][delay,1]* So why not give me\n  more to do?[/page]";
global.msg[7] = "[character,chai,angry][delay,1]* Make me get ingredients\n  every night while you're\n  at it![/page]";
global.msg[8] = "[character,chai,neutral][delay,1]* ...[/page]";
global.msg[9] = "[character,chai,rolleyes][delay,1]* The worst part is she\n  won't let me hang\n  out with my friends.[/page]";
global.msg[10] = "[character,chai,angry][delay,1]* Says they're bad\n  influences.[/page]";
global.msg[11] = "[character,chai,angry][delay,1]* How are they the bad\n  ones!?[/page]";
global.msg[12] = "[character,chai,angry][delay,1]* You're the one that\n  ran off after I told\n  you to stay put.[/page]";
global.msg[13] = "[character,chai,angry][delay,1]* Why!?[/page]";
global.msg[14] = "[character,chai,angry][delay,1]* What could've possessed\n  you to do something\n  this stupid?[/page]";
global.msg[15] = "[character,chai,angry][delay,1]* I'm trying to have a\n  nice night.[/page]";
global.msg[16] = "[character,chai,angry][delay,1]* Can't you just do\n  what I say for one\n  minute?[/page]";
global.msg[17] = "[character,none,-1][delay,1]* (You tell her you saw dad in\n  the woods.)[/page]";
global.msg[18] = "[character,chai,disappointedcry][delay,1]* ...[/page]";
global.msg[19] = "[character,chai,needtolockin][delay,1]* ...[/page]";
global.msg[20] = "[character,chai,tweakeraway][delay,1]* ...[/page]";
global.msg[21] = "[character,chai,sobbing][delay,1]* Oh...[freeze][delay,333][continue]\n* Olive...[/page]";
global.msg[22] = "[character,chai,sobbing][delay,1]* I didn't...[/page]";
global.msg[23] = "[character,chai,blink][delay,1]* I didn't even...[freeze][delay,333][continue]\n* Wanna go tonight...[/page]";
global.msg[24] = "[character,chai,sobbing][delay,1]* The only reason I'm\n  out here...[/page]";
global.msg[25] = "[character,chai,sobbing][delay,1]* Is because they were\n  doing...[freeze][delay,333][continue]\n* Bad things...[/page]";
global.msg[26] = "[character,chai,sobbingatyou][delay,1]* Not even for you![/page]";
global.msg[27] = "[character,chai,sobbingatyou][delay,1]* I didn't care about\n  you until you weren't\n  in the car.[/page]";
global.msg[28] = "[character,none,-1][delay,1]* (You tell Chai it's okay.)[/page]";
global.msg[29] = "[character,chai,sadsmile][delay,1]* ...[/page]";
global.msg[30] = "[character,chai,sadsmile][delay,1]* No,[freeze][delay,333][continue] Olive.[/page]";
global.msg[31] = "[character,chai,sadsmile][delay,1]* It's not okay.[/page]";
global.msg[32] = "[character,chai,tweaker][delay,1]* You're not another chore\n  mom gave me.[/page]";
global.msg[33] = "[character,chai,tweaker][delay,1]* And you're not the\n  reason...[/page]";
global.msg[34] = "[character,chai,tweaker][delay,1]* ...[chaigetup]";
global.msg_esp[0] = "[character,chai,neutral][delay,1]* Se supone que\n  debería estar en\n  el monte Ebott.[/page]";
global.msg_esp[1] = "[character,chai,rolleyes][delay,1]* Hoy y mañana.[/page]";
global.msg_esp[2] = "[character,chai,angry][delay,1]* Quiero decir,[freeze][delay,333][continue] quién\n  se cree mamá que\n  es?[/page]";
global.msg_esp[3] = "[character,chai,angry][delay,1]* Me mato a trabajar\n  en la escuela.[/page]";
global.msg_esp[4] = "[character,chai,angry][delay,1]* Ayudo a la pandilla\n  durante toda la\n  noche.[/page]";
global.msg_esp[5] = "[character,chai,angry][delay,1]* Limpio la casa antes\n  de irme a dormir.[/page]";
global.msg_esp[6] = "[character,chai,angry][delay,1]* ¿Por qué me da\n  más preocupaciones?[/page]";
global.msg_esp[7] = "[character,chai,angry][delay,1]* ¡Venga,[freeze][delay,333][continue] hazme ir a\n  por ingredientes todas\n  las noches ya...[/page]";
global.msg_esp[8] = "[character,chai,neutral][delay,1]* ...que estamos![/page]";
global.msg_esp[9] = "[character,chai,rolleyes][delay,1]* Lo peor es que no\n  deja quedar con mis\n  amigas por la noche.[/page]";
global.msg_esp[10] = "[character,chai,angry][delay,1]* 'Son malas influencias',[freeze][delay,333][continue]\n  dice.[/page]";
global.msg_esp[11] = "[character,chai,angry][delay,1]* ¿¡Cómo son ellas las\n  malas!?[/page]";
global.msg_esp[12] = "[character,chai,angry][delay,1]* Tú eres la que salió\n  corriendo cuando te\n  dije de quedarte...[/page]";
global.msg_esp[13] = "[character,chai,angry][delay,1]* ¿¡Por qué!?[/page]";
global.msg_esp[14] = "[character,chai,angry][delay,1]* ¿Qué te ha podido poseer\n  para que hicieras\n  algo tan estúpido?[/page]";
global.msg_esp[15] = "[character,chai,angry][delay,1]* Estoy intentando tener\n  una buena noche.[/page]";
global.msg_esp[16] = "[character,chai,angry][delay,1]* ¿No podrías hacer\n  lo que yo te digo\n  por un minuto?[/page]";
global.msg_esp[17] = "[character,none,-1][delay,1]* (Le dices que viste a papá\n  entrar al bosque.)[/page]";
global.msg_esp[18] = "[character,chai,disappointedcry][delay,1]* ...[/page]";
global.msg_esp[19] = "[character,chai,needtolockin][delay,1]* ...[/page]";
global.msg_esp[20] = "[character,chai,tweakeraway][delay,1]* ...[/page]";
global.msg_esp[21] = "[character,chai,sobbing][delay,1]* Oh...[freeze][delay,333][continue]\n* Olive...[/page]";
global.msg_esp[22] = "[character,chai,sobbing][delay,1]* Yo ni...[/page]";
global.msg_esp[23] = "[character,chai,blink][delay,1]* Yo ni siquiera...[freeze][delay,333][continue]\n* Quería salir hoy...[/page]";
global.msg_esp[24] = "[character,chai,sobbing][delay,1]* La única razón\n  del porqué estoy\n  aquí afuera...[/page]";
global.msg_esp[25] = "[character,chai,sobbing][delay,1]* Es porque estaban\n  haciendo...[freeze][delay,333][continue]\n* Cosas malas...[/page]";
global.msg_esp[26] = "[character,chai,sobbingatyou][delay,1]* ¡Ni siquiera estoy\n  aquí para tí![/page]";
global.msg_esp[27] = "[character,chai,sobbingatyou][delay,1]* Ni siquiera me\n  importaste hasta que\n  no te ví...[/page]";
global.msg_esp[28] = "[character,none,-1][delay,1]* (Le dices a Chai que está\n  bien.)[/page]";
global.msg_esp[29] = "[character,chai,sadsmile][delay,1]* ...[/page]";
global.msg_esp[30] = "[character,chai,sadsmile][delay,1]* No,[freeze][delay,333][continue] Olive.[/page]";
global.msg_esp[31] = "[character,chai,sadsmile][delay,1]* No está bien.[/page]";
global.msg_esp[32] = "[character,chai,tweaker][delay,1]* Tú no eres otro recado\n  que mamá me ha dicho\n  de hacer.[/page]";
global.msg_esp[33] = "[character,chai,tweaker][delay,1]* Y tú no eres la\n  razón por la que...[/page]";
global.msg_esp[34] = "[character,chai,tweaker][delay,1]* ...[chaigetup]";
instance_create_depth(x, y, -1000, obj_textboxNEW);
