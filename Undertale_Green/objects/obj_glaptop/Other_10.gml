global.msg[0] = "[character,none,-1][delay,1]* ...![/page]";
global.msg[1] = "[character,none,-1][delay,1]* Your mom has one of these.[/page]";
global.msg[2] = "[character,none,-1][delay,1]* She uses it to look at the\n  bakery's money.[delay,333] She always\n  cries when she's on it.[/page]";
