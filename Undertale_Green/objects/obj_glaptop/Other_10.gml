global.msg_esp[1] = "[character,none,-1][delay,1]* Mamá tiene una de estas.[/page]";
global.msg_esp[2] = "[character,none,-1][delay,1]* La utiliza mucho en vuestra pastelería\n  para ver el dinero ganado.\n[delay,333]  Siempre que lo hace llora.[/page]";
