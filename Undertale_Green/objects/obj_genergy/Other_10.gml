global.msg[0] = "[character,none,-1][delay,1]* Your sister drinks this stuff\n  all the time.[/page]";
global.msg[1] = "[character,none,-1][delay,1]* She tells you it helps her stay\n  awake.[/page]";
global.msg[2] = "[character,none,-1][delay,1]* For you,[delay,333] it's apple juice.";
global.msg_esp[0] = "[character,none,-1][delay,1]* Tu hermana bebe esto\n cada vez que puede.[/page]";
global.msg_esp[1] = "[character,none,-1][delay,1]* Siempre te dice que la mantiene\n  despierta.[/page]";
global.msg_esp[2] = "[character,none,-1][delay,1]* Para tí,[delay,333] esto es zumo de manzano.";
