global.msg[0] = "[character,gray,dramatic][delay,1][owsprite,gray_gr,dramatic][funnylighton]* Goodbye,[freeze][delay,333][continue] cruel world![freeze][delay,333][continue]\n* I can...[freeze][delay,333][continue] I can see\n  the light![/page]";
global.msg[1] = "[character,eden,angry][delay,1][owsprite,gray_gr,default][funnylightoff]* You can stop anytime,[freeze][delay,333][continue]\n  Gray.[/page]";
global.msg[2] = "[character,gray,dramatic][delay,1][owsprite,gray_gr,dramatic][funnylighton2]* Little Chai...[freeze][delay,333][continue]\n* Tell my family...[freeze][delay,333][continue]\n* Tell them...[/page]";
global.msg[3] = "[character,eden,angry][delay,1][owsprite,gray_gr,default][funnylightoff]* You know their name is\n  Olive,[freeze][delay,333][continue] right?[/page]";
global.msg[4] = "[character,eden,angry][delay,1]* I can't believe they\n  actually told you...[/page]";
global.msg[5] = "[character,gray,dramatic][delay,1][owsprite,gray_gr,dramatic][funnylighton2]* It's a cruel world,[freeze][delay,333][continue]\n  little Chai![/page]";
global.msg[6] = "[character,gray,dramatic][delay,1]* A world I no longer\n  belong to.[/page]";
global.msg[7] = "[character,eden,angry][delay,1][owsprite,gray_gr,default][funnylightoff]* I don't think you're\n  ever getting out of the\n  doghouse.[/page]";
global.msg[8] = "[character,gray,smug][delay,1]* Listen,[freeze][delay,333][continue] it's not my\n  fault you're so easy\n  to make fun of.[/page]";
global.msg[9] = "[character,eden,sly][delay,1]* Well it's not my fault\n  you're five-five at\n  seventeen either.[freeze][delay,333][continue] So.[/page]";
global.msg[10] = "[character,gray,shocked][owsprite,gray_gr,happy][delay,1]* Eden![freeze][delay,333][continue]\n* I can't believe you![/page]";
global.msg[11] = "[character,eden,sly][delay,1]* Shut up.[/page]";
global.msg[12] = "[character,gray,happy][delay,1]* You wound me,[freeze][delay,333][continue] my pawn.[/page]";
global.msg[13] = "[character,eden,cluckin][delay,1]* And you say I'm easy\n  to make fun of.[pitpunks]";
global.msg_esp[0] = "[character,gray,dramatic][delay,1][owsprite,gray_gr,dramatic][funnylighton]* ¡Adiós,[freeze][delay,333][continue] mundo cruel![freeze][delay,333][continue]\n* Ya puedo...[freeze][delay,333][continue] ¡Ya puedo\n  ver la luz![/page]";
global.msg_esp[1] = "[character,eden,angry][delay,1][owsprite,gray_gr,default][funnylightoff]* Vale,[freeze][delay,333][continue] vale,[freeze][delay,333][continue] ya puedes\n  parar,[freeze][delay,333][continue] Gray.[/page]";
global.msg_esp[2] = "[character,gray,dramatic][delay,1][owsprite,gray_gr,dramatic][funnylighton2]* Mini-Chai...[freeze][delay,333][continue]\n* Dile a mi familia...[freeze][delay,333][continue]\n* Diles que yo...[/page]";
global.msg_esp[3] = "[character,eden,angry][delay,1][owsprite,gray_gr,default][funnylightoff]* Su nombre es Olive,[freeze][delay,333][continue]\n  ¿sabes?[/page]";
global.msg_esp[4] = "[character,eden,angry][delay,1]* No me puedo creer que\n  que te lo haya contado...[/page]";
global.msg_esp[5] = "[character,gray,dramatic][delay,1][owsprite,gray_gr,dramatic][funnylighton2]* ¡Demasiado cruel!,[freeze][delay,333][continue]\n  ¡mini-Chai![/page]";
global.msg_esp[6] = "[character,gray,dramatic][delay,1]* Un mundo al que ya\n  no pertenezco.[/page]";
global.msg_esp[7] = "[character,eden,angry][delay,1][owsprite,gray_gr,default][funnylightoff]* Definitivamente hoy\n  vas directo al sofá.[/page]";
global.msg_esp[8] = "[character,gray,smug][delay,1]* Mira,[freeze][delay,333][continue] no es mi culpa\n  que me pueda meter\n  tan facilmente contigo.[/page]";
global.msg_esp[9] = "[character,eden,sly][delay,1]* Tampoco es mi culpa\n  que midas metro y medio\n  con 17 años...[freeze][delay,333][continue] ¿No?[/page]";
global.msg_esp[10] = "[character,gray,shocked][owsprite,gray_gr,happy][delay,1]* ¡Eden![freeze][delay,333][continue]\n* ¡No me lo creo![/page]";
global.msg_esp[11] = "[character,eden,sly][delay,1]* Calla.[/page]";
global.msg_esp[12] = "[character,gray,happy][delay,1]* Me hieres,[freeze][delay,333][continue] peón mío.[/page]";
global.msg_esp[13] = "[character,eden,cluckin][delay,1]* Y dices que soy un\n  blanco fácil para\n  tus bromas.[pitpunks]";
instance_create_depth(x, y, -1000, obj_textboxNEW);
instance_create_depth(obj_player.x, obj_player.y, -500, obj_player_dummy);
