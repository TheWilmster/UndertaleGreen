global.msg[0] = "[character,alaska,disleftFB][delay,1]* Where are the matches,[freeze][delay,333][continue]\n  Destiny?[/page]";
global.msg[1] = "[character,destiny,frustratedFB][delay,1]* They should be somewhere\n  in here.[/page]";
global.msg[2] = "[character,alaska,disrightFB][delay,1]* Well hurry up,[freeze][delay,333][continue] okay?[freeze][delay,333][continue]\n* It's dark in here.[/page]";
global.msg[3] = "[character,destiny,distractedFB][delay,1]* I know,[freeze][delay,333][continue] right?[/page]";
global.msg[4] = "[character,destiny,distractedFB][delay,1]* You won't even see\n  the monsters when they\n  come to eat you.[/page]";
global.msg[5] = "[character,alaska,hehFB][delay,1]* They would so eat you\n  first.[/page]";
global.msg[6] = "[character,kaitlyn,smugFB][delay,1]* If they're eating\n  anyone first,[freeze][delay,333][continue] it's me.[/page]";
global.msg[7] = "[character,destiny,distractedFB][delay,1]* Good for you...?[/page]";
global.msg[8] = "[character,kaitlyn,neutralFB][delay,1]* Like,[freeze][delay,333][continue] I think I'd\n  be the most desirable.[/page]";
global.msg[9] = "[character,chai,dreamworksFB][delay,1]* To be eaten...?[/page]";
global.msg[10] = "[character,destiny,distractedFB][delay,1]* Is this something you're\n  proud of?[/page]";
global.msg[11] = "[character,kaitlyn,madFB][delay,1]* Shut up Destiny![freeze][delay,333][continue]\n* I'm just saying...[/page]";
global.msg[12] = "[character,destiny,founditFB][delay,1]* There you are![lightfire]";
global.msg_esp[0] = "[character,alaska,disleftFB][delay,1]* ¿Dónde están las\n  cerillas,[freeze][delay,333][continue] Destiny?[/page]";
global.msg_esp[1] = "[character,destiny,frustratedFB][delay,1]* Tienen que estar\n  por aquí cerca.[/page]";
global.msg_esp[2] = "[character,alaska,disrightFB][delay,1]* Pues date prisa,[freeze][delay,333][continue]\n  ¿vale?[freeze][delay,333][continue]\n* Está muy oscuro.[/page]";
global.msg_esp[3] = "[character,destiny,distractedFB][delay,1]* No me digas,[freeze][delay,333][continue] ¿en serio?[/page]";
global.msg_esp[4] = "[character,destiny,distractedFB][delay,1]* Ni podrás ver a\n  los monstruos cuando\n  vengan y te coman.[/page]";
global.msg_esp[5] = "[character,alaska,hehFB][delay,1]* Te comerían a tí\n  la primera.[/page]";
global.msg_esp[6] = "[character,kaitlyn,smugFB][delay,1]* Si comen a alguien\n  la primera,[freeze][delay,333][continue] esa soy\n  yo.[/page]";
global.msg_esp[7] = "[character,destiny,distractedFB][delay,1]* ¿Bien para...[freeze][delay,333][continue] tí...?[/page]";
global.msg_esp[8] = "[character,kaitlyn,neutralFB][delay,1]* En plan,[freeze][delay,333][continue] creo que\n  sería la más\n  atractiva.[/page]";
global.msg_esp[9] = "[character,chai,dreamworksFB][delay,1]* Para que...[freeze][delay,333][continue] ¿te coman...?[/page]";
global.msg_esp[10] = "[character,destiny,distractedFB][delay,1]* ¿A caso te\n  enorgullece?[/page]";
global.msg_esp[11] = "[character,kaitlyn,madFB][delay,1]* ¡Cállate Destiny![freeze][delay,333][continue]\n* Solo digo que...[/page]";
global.msg_esp[12] = "[character,destiny,founditFB][delay,1]* ¡Aquí están![lightfire]";
instance_create_depth(x, y, -1000, obj_textboxNEW);
