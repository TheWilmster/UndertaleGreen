global.msg[0] = "[character,none,-1][delay,5]* Hey girl.[delay,333] I'm surprised your\n  parents let you up here.[/page]";
global.msg[1] = "[character,none,-1][delay,5]* My mom would like,[delay,333] kill me\n  if she knew I was out of the\n  house right now.[/page]";
global.msg[2] = "[character,none,-1][delay,5]* She always thinks I'm like,[delay,333]\n  at parties and hanging out with boys.[/page]";
global.msg[3] = "[character,none,-1][delay,5]* And I'm like mom like,[delay,333] didn't\n  you just buy that wine bottle this morning?[/page]";
global.msg[4] = "[character,none,-1][delay,5]* [delay,333]...[/page]";
global.msg[4] = "[character,none,-1][delay,5]* Why don't you gather the girls, okay? I got some good stories for tonight.";
instance_create_depth(x, y, -1000, obj_textboxNEW);
