global.msg[0] = "[character,none,-1][delay,1]* It's a top hat.[delay,333]\n* You wonder whose costume it's\n  for.[/page]";
global.msg[1] = "[character,none,-1][delay,1]* You think about how in a\n  few years it could be your\n  costume.[/page]";
global.msg[2] = "[character,none,-1][delay,1]* You've become captivated by\n  this idea.[/page]";
global.msg[3] = "[character,none,-1][delay,1]* ...[delay,333][victory]You're now on the Top Hat\n  Route.";
global.msg_esp[0] = "[character,none,-1][delay,1]* Es un sombrero de copa.[delay,333]\n* Te preguntad quién llevará\n  el disfraz.[/page]";
global.msg_esp[1] = "[character,none,-1][delay,1]* Piensas como en algunos años\n  este podría llegar a ser tu\n  disfraz.[/page]";
global.msg_esp[2] = "[character,none,-1][delay,1]* Te ha captivado mucho esta\n  idea.[/page]";
global.msg_esp[3] = "[character,none,-1][delay,1]* ...[delay,333][victory]Has desbloqueado la Ruta\n  Sombrero de Copa.";
