global.msg[0] = "[character,chai,smileleft][owsprite,chai,smile][delay,1]* ...[/page]";
global.msg[1] = "[character,chai,smile][delay,1]* I picked up your chess\n  pieces.[/page]";
global.msg[2] = "[character,chai,smile][delay,1]* They fell out of your\n  pocket when you\n  tripped.[/page]";
global.msg[3] = "[character,chai,blushsmirk][delay,1]* I uhh...[/page]";
global.msg[4] = "[character,chai,blushsmile][delay,1]* Well I kept the queen.[freeze][delay,333][continue]\n* In my pocket.[/page]";
global.msg[5] = "[character,chai,blushsmile][delay,1]* I figured like,[freeze][delay,333][continue] if\n  you weren't dead after\n  you tripped...[/page]";
global.msg[6] = "[character,chai,blushsmirk][delay,1]* I could play pretend\n  with you or whatever.[/page]";
global.msg[7] = "[character,chai,blushsmile][delay,1]* Don't you dare hug me\n  again,[freeze][delay,333][continue] alright?[/page]";
global.msg[8] = "[character,chai,smile][delay,1]* ...[/page]";
global.msg[9] = "[character,chai,smile][delay,1]* I know you always\n  wanted me to be the\n  queen.[/page]";
global.msg[10] = "[character,chai,smile][delay,1]* Well you better prepare\n  yourself.[/page]";
global.msg[11] = "[character,chai,smile][delay,1]* Your bishop stands no\n  chance against my\n  kingdom's military might.[/page][battle,chai]";
global.msg_esp[0] = "[character,chai,smileleft][owsprite,chai,smile][delay,1]* ...[/page]";
global.msg_esp[1] = "[character,chai,smile][delay,1]* He recogido tus\n  piezas de ajedrez.[/page]";
global.msg_esp[2] = "[character,chai,smile][delay,1]* Se cayeron de tus\n  bolsillos cuando\n  te caiste.[/page]";
global.msg_esp[3] = "[character,chai,blushsmirk][delay,1]* Yo ehh...[/page]";
global.msg_esp[4] = "[character,chai,blushsmile][delay,1]* Me he quedado con\n  la reina.[freeze][delay,333][continue]\n* La tengo conmigo.[/page]";
global.msg_esp[5] = "[character,chai,blushsmile][delay,1]* Creía que si...[freeze][delay,333][continue] Tipo,[freeze][delay,333][continue]\n  si no habías muerto\n  después de caerte...[/page]";
global.msg_esp[6] = "[character,chai,blushsmirk][delay,1]* Podíamos jugar\n  a las peleas.[/page]";
global.msg_esp[7] = "[character,chai,blushsmile][delay,1]* Ni se te ocurra\n  abrazarme de nuevo,[freeze][delay,333][continue]n  ¿vale?[/page]";
global.msg_esp[8] = "[character,chai,smile][delay,1]* ...[/page]";
global.msg_esp[9] = "[character,chai,smile][delay,1]* Siempre quisiste\n  que yo fuera la\n  reina.[/page]";
global.msg_esp[10] = "[character,chai,smile][delay,1]* Pues vete\n  preparándote.[/page]";
global.msg_esp[11] = "[character,chai,smile][delay,1]* Tu alfíl no tiene\n  nada que hacer contra\n  mi gran ejército.[/page][battle,chai]";
instance_create_depth(x, y, -1000, obj_textboxNEW);
